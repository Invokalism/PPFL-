<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ListReport1._3</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous">
    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ListReport1._3.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/custom.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>


</head>
<body>

    <!-- Top Navbar -->
    <nav class="navbar navbar-expand-sm custom-navbar">
        <div class="container-fluid">
            <a class="navbar-brand brand-logo" href="#">
                Pacific and Premium Freight Logistics Inc
            </a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarTop"
                    aria-controls="navbarTop" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse justify-content-end" id="navbarTop">
                @DateTime.Now.ToString("dddd, MMMM dd, yyyy")
            </div>
        </div>
    </nav>

    <div class="d-flex layout-wrapper">

        <!-- Sidebar -->
        <div class="d-flex flex-column flex-shrink-0 p-3 sidebar">
            
            <hr>

            <ul class="nav nav-pills flex-column mb-auto">
                <li class="nav-item">

                    <a asp-controller="ShippingDetails" asp-action="Table" class="nav-link " aria-current="page">
                        <i class="bi bi-truck"></i>
                        Shipment Details
                    </a>
                </li>
                <li>
                    <a asp-controller="ShippingDetails" class="nav-link " asp-action="Payables" aria-current="page">
                        <i class="bi bi-cash"></i>
                        Payables
                    </a>
                </li>
                <li>
                    <a asp-controller="ShippingDetails" class="nav-link " asp-action="Billing" aria-current="page">
                        <i class="bi bi-receipt"></i>
                        Billing Statement | Revenue | Profit
                    </a>
                </li>
                @*<li>
                    <a href="#" class="nav-link ">
                        <svg class="bi pe-none me-2" width="16" height="16" aria-hidden="true">
                            <use xlink:href="#grid"></use>
                        </svg>
                    </a>
                </li>
                <li>
                    <a href="#" class="nav-link ">
                        <svg class="bi pe-none me-2" width="16" height="16" aria-hidden="true">
                            <use xlink:href="#people-circle"></use>
                        </svg>
                    </a>
                </li>*@
            </ul>

            <hr>
        </div>

        <!-- Main Content -->
        <div class="flex-grow-1 p-3">
            @RenderBody()
        </div>

    </div>

   @* <footer class="border-top footer text-muted mt-auto">
        <div class="container">
            &copy; 2026 - ListReport1._3 - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>*@

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>