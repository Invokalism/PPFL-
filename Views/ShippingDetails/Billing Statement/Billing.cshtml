@model IEnumerable<ListReport1._3.Models.ShippingDetails>

@{
    ViewData["Title"] = "Billings Statement | Revenue| Profit";
}

<div class="container mt-2 narrow-container">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-3">

        <div class="dashboard-header d-flex align-items-center gap-2">
            <div class="icon-box">
                <i class="bi bi-receipt"></i>
            </div>
            <h4 class="mb-0">Billings Statement | Revenue | Profit</h4>
        </div>

        <div class="d-flex align-items-center gap-2">

            <button type="button" id="printBtn" class="btn-pill btn-secondary-pill">
                <i class="bi bi-printer"></i> Print
            </button>

            <button type="button" id="exportBtn" class="btn-pill btn-success-pill">
                <i class="bi bi-file-earmark-spreadsheet"></i> Export
            </button>

            <div class="search d-flex">
                <input type="text" id="searchInput" class="searchTerm form-control" placeholder="Search">
                <button class="searchButton btn btn-outline-secondary">
                    <i class="bi bi-search"></i>
                </button>
            </div>

        </div>
    </div>

    <!-- TABLE -->
    <div id="printArea" class="table-responsive" style="max-height:700px; overflow-y:auto;">
        <table class="table table-hover align-middle table-custom">

            <thead>
                <tr>
                    <th>@Html.DisplayNameFor(m => m.JobNo)</th>
                    <th>@Html.DisplayNameFor(m => m.SlNum)</th>
                    <th>@Html.DisplayNameFor(m => m.SlNumAmount)</th>
                    <th>@Html.DisplayNameFor(m => m.Ewt)</th>
                    <th>@Html.DisplayNameFor(m => m.EwtTotal)</th>
                    <th>@Html.DisplayNameFor(m => m.DmPhp)</th>
                    <th>@Html.DisplayNameFor(m => m.DmPhpAmount)</th>
                    <th>@Html.DisplayNameFor(m => m.DmUsd)</th>
                    <th>@Html.DisplayNameFor(m => m.DmUsdAmount)</th>
                    <th>@Html.DisplayNameFor(m => m.Revenue)</th>
                    <th>@Html.DisplayNameFor(m => m.ProfitFrom)</th>
                    <th>@Html.DisplayNameFor(m => m.ProfitAmount)</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.JobNo</td>
                        <td>@item.SlNum</td>

                        <td>₱ @((item.SlNumAmount ?? 0).ToString("N2"))</td>
                        <td>@item.Ewt</td>
                        <td>₱ @((item.EwtTotal ?? 0).ToString("N2"))</td>

                        <td>@item.DmPhp</td>
                        <td>₱ @((item.DmPhpAmount ?? 0).ToString("N2"))</td>

                        <td>@item.DmUsd</td>
                        <td>$ @((item.DmUsdAmount ?? 0).ToString("N2"))</td>

                        <td>₱ @((item.Revenue ?? 0).ToString("N2"))</td>
                        <td>@item.ProfitFrom</td>
                        <td>₱ @((item.ProfitAmount ?? 0).ToString("N2"))</td>

                        <td class="text-center">
                            <div class="d-flex flex-column gap-2 align-items-center">
                                <button class="btn-pill btn-info-pill btn-sm editBtn"
                                        data-id="@item.ID">
                                    <i class="bi bi-pencil-square"></i> Edit
                                </button>

                                <button class="btn-pill btn-danger-pill btn-sm deleteBtn"
                                        data-id="@item.ID">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>

        </table>
    </div>

    <!-- TOTAL REVENUE -->
    <div class="d-flex justify-content-end mt-2">
        <div>
            <span>Total Revenue:</span>
            <strong id="totalRevenue">₱ 0.00</strong>
        </div>
    </div>

</div>

<!-- EDIT MODAL -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header custom-modal-header">
                <h5 class="modal-title">Edit Billing</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body" id="editModalBody">
                <div class="text-center">
                    <span class="spinner-border"></span> Loading form...
                </div>
            </div>
        </div>
    </div>
</div>

<!-- DELETE MODAL -->
<div class="modal fade" id="deleteConfirmModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete Billing</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body text-center">
                <p>Are you sure you want to delete this record?</p>
            </div>

            <div class="modal-footer justify-content-center">
                <button id="confirmDeleteBtn" class="btn btn-danger">Delete</button>
                <button class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            // 🔹 SEARCH + TOTAL UPDATE
            const searchInput = document.getElementById("searchInput");
            const tableBody = document.querySelector(".table-custom tbody");

            if (searchInput && tableBody) {
                searchInput.addEventListener("keyup", function () {
                    const filter = this.value.toLowerCase();
                    const rows = tableBody.querySelectorAll("tr");

                    rows.forEach(row => {
                        row.style.display =
                            row.textContent.toLowerCase().includes(filter) ? "" : "none";
                    });

                    updateTotalRevenue();
                });
            }

            // 🔹 TOTAL REVENUE FUNCTION
            function updateTotalRevenue() {
                let total = 0;

                document.querySelectorAll(".table-custom tbody tr").forEach(row => {
                    if (row.style.display === "none") return;

                    const cells = row.querySelectorAll("td");
                    let value = cells[9]?.innerText || "0";

                    value = value.replace(/[₱,$]/g, "").replace(/,/g, "");

                    total += parseFloat(value) || 0;
                });

                document.getElementById("totalRevenue").innerText =
                    "₱ " + total.toLocaleString(undefined, { minimumFractionDigits: 2 });
            }

            // INITIAL LOAD
            updateTotalRevenue();
            // ===============================
            // 🔹 EXPORT VISIBLE TABLE TO CSV (WITHOUT ACTIONS COLUMN)
            // ===============================
            const exportBtn = document.getElementById("exportBtn");
            if (exportBtn) {
                exportBtn.addEventListener("click", function () {
                    const table = document.querySelector(".table-custom");
                    if (!table) return;

                    let csv = [];

                    // Add a custom header row
                    csv.push('"Billings Statement | Revenue| Profit"'); // <-- This is your top header row

                    // Optionally, add an empty row between title and table headers
                    csv.push(''); // blank row

                    // Add table headers (exclude last column)
                    const headers = table.querySelectorAll("thead th");
                    let headerData = [];
                    for (let i = 0; i < headers.length - 1; i++) { // Exclude last column (Actions)
                        let text = headers[i].innerText.replace(/"/g, '""');
                        headerData.push(`"${text}"`);
                    }
                    csv.push(headerData.join(","));

                    // Loop through visible rows
                    const rows = table.querySelectorAll("tbody tr");
                    rows.forEach(row => {
                        if (row.style.display === "none") return; // Skip hidden rows

                        const cols = row.querySelectorAll("td");
                        let rowData = [];
                        for (let i = 0; i < cols.length - 1; i++) { // Exclude last column (Actions)
                            let text = cols[i].innerText.replace(/"/g, '""');
                            rowData.push(`"${text}"`);
                        }
                        csv.push(rowData.join(","));
                    });

                    // Create CSV file and trigger download
                    const csvFile = new Blob([csv.join("\n")], { type: "text/csv" });
                    const downloadLink = document.createElement("a");
                    downloadLink.download = "ShippingDetails.csv";
                    downloadLink.href = window.URL.createObjectURL(csvFile);
                    downloadLink.style.display = "none";
                    document.body.appendChild(downloadLink);
                    downloadLink.click();
                    document.body.removeChild(downloadLink);
                });
            }
            // ===============================
            // 🔹 EDIT PAYABLE MODAL (UPDATED)
            // ===============================
            document.querySelectorAll(".editBtn").forEach(btn => {
                btn.addEventListener("click", function () {

                    const id = this.dataset.id;
                    const editModalEl = document.getElementById("editModal");
                    const modalBody = document.getElementById("editModalBody");

                    if (!editModalEl || !modalBody) return;

                    const editModal = new bootstrap.Modal(editModalEl);
                    editModal.show();

                    modalBody.innerHTML = '<div class="text-center"><span class="spinner-border"></span> Loading form...</div>';

                    // ✅ USE BILLING ENDPOINT
                    fetch(`/ShippingDetails/EditBilling/${id}`)
                        .then(res => res.text())
                        .then(html => {
                            modalBody.innerHTML = html;

                            const form = document.getElementById("editForm");
                            if (!form) return;

                            form.addEventListener("submit", function (e) {
                                e.preventDefault();

                                fetch(form.action, {
                                    method: "POST",
                                    body: new FormData(form)
                                })
                                    .then(res => res.text())
                                    .then(result => {
                                        try {
                                            const json = JSON.parse(result);

                                            if (json.success) {

                                                // ✅ SUCCESS MODAL (UPDATED DESIGN)
                                                const successModalHtml = `
                                                <div class="modal fade" id="successModal" tabindex="-1">
                                                    <div class="modal-dialog modal-dialog-centered">
                                                        <div class="modal-content success-modal">

                                                            <div class="modal-header border-0 pb-0">
                                                                <h5 class="modal-title fw-semibold">Success</h5>
                                                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                            </div>

                                                            <div class="modal-body text-center pt-2">

                                                                <div class="success-icon">
                                                                    <i class="bi bi-check-circle"></i>
                                                                </div>

                                                                <p class="success-text">
                                                                    Payable details updated successfully!
                                                                </p>

                                                                <p class="success-subtext">
                                                                    Your changes have been saved.
                                                                </p>

                                                            </div>

                                                        </div>
                                                    </div>
                                                </div>`;

                                                document.body.insertAdjacentHTML('beforeend', successModalHtml);

                                                const successModal = new bootstrap.Modal(document.getElementById('successModal'));
                                                successModal.show();

                                                setTimeout(() => {
                                                    successModal.hide();

                                                    // ✅ Redirect to PAYABLES page (NOT table)
                                                    window.location.href = '/ShippingDetails/Billing';

                                                }, 1500);

                                                return;
                                            }
                                        } catch { }

                                        modalBody.innerHTML = result;
                                    });
                            });
                        })
                        .catch(err => {
                            modalBody.innerHTML = '<div class="alert alert-danger">Failed to load form.</div>';
                            console.error(err);
                        });
                });
            });
            // ===============================
            // 🔹 DELETE PAYABLE MODAL (UPDATED)
            // ===============================
            let deleteId = null;

            // Show modal when delete button clicked
            document.querySelectorAll(".deleteBtn").forEach(btn => {
                btn.addEventListener("click", function () {
                    deleteId = this.dataset.id; // store the ID
                    const deleteModal = new bootstrap.Modal(document.getElementById("deleteConfirmModal"));
                    deleteModal.show();
                });
            });

            // Confirm deletion
            document.getElementById("confirmDeleteBtn").addEventListener("click", function () {
                if (!deleteId) return;

                fetch(`/ShippingDetails/DeleteFlag/${deleteId}`, { method: "POST" })
                    .then(res => res.json())
                    .then(result => {
                        if (result.success) {
                            const successModalHtml = `
                                            <div class="modal fade" id="successModal" tabindex="-1">
                                                <div class="modal-dialog modal-dialog-centered">
                                                    <div class="modal-content success-modal">

                                                        <!-- Header -->
                                                        <div class="modal-header border-0 pb-0">
                                                            <h5 class="modal-title fw-semibold">Success</h5>
                                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                        </div>

                                                        <!-- Body -->
                                                        <div class="modal-body text-center pt-2">

                                                            <div class="success-icon">
                                                                <i class="bi bi-check-circle"></i>
                                                            </div>

                                                            <p class="success-text">
                                                                Shipment details deleted successfully!
                                                            </p>

                                                            <p class="success-subtext">
                                                                The record has been marked as deleted.
                                                            </p>

                                                        </div>

                                                        <!-- Footer -->


                                                    </div>
                                                </div>
                                            </div>`;
                            document.body.insertAdjacentHTML('beforeend', successModalHtml);
                            const successModal = new bootstrap.Modal(document.getElementById('successModal'));
                            successModal.show();

                            setTimeout(() => {
                                successModal.hide();
                                window.location.href = '@Url.Action("Billing", "ShippingDetails")';
                            }, 1500);
                            return;
                        } else {
                            alert("Failed to delete the record.");
                        }
                    })
                    .catch(err => {
                        console.error(err);
                        alert("Error occurred while deleting.");
                    });

                // Hide modal
                const deleteModalEl = document.getElementById("deleteConfirmModal");
                const deleteModal = bootstrap.Modal.getInstance(deleteModalEl);
                deleteModal.hide();
            });
            // ===============================
            // 🔹 PRINT TABLE
            // ===============================
            document.getElementById("printBtn").addEventListener("click", function () {

                const rows = document.querySelectorAll(".table-custom tbody tr");
                let visibleData = [];

                rows.forEach(row => {
                    if (row.style.display !== "none") {

                        const cells = row.querySelectorAll("td");

                        visibleData.push({
                            JobNo: cells[0].innerText,
                            SlNum: cells[1].innerText,
                            SlNumAmount: parseFloat(cells[2].innerText.replace(/[₱,]/g, "")) || 0,
                            Ewt: parseFloat(cells[3].innerText.replace(/[₱,]/g, "")) || 0,
                            EwtTotal: parseFloat(cells[4].innerText.replace(/[₱,]/g, "")) || 0,
                            DmPhp: cells[5].innerText,
                            DmPhpAmount: parseFloat(cells[6].innerText.replace(/[₱,]/g, "")) || 0,
                            DmUsd: cells[7].innerText,
                            DmUsdAmount: parseFloat(cells[8].innerText.replace(/[$,]/g, "")) || 0,
                            Revenue: parseFloat(cells[9].innerText.replace(/[₱,]/g, "")) || 0,
                            ProfitFrom: cells[10].innerText,
                            ProfitAmount: parseFloat(cells[11].innerText.replace(/[₱,]/g, "")) || 0
                        });
                    }
                });

                const printUrl = '@Url.Action("PrintBilling", "ShippingDetails")';
                fetch(printUrl, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(visibleData)
                })
                    .then(response => response.text())
                    .then(html => {
                        const printWindow = window.open('', '_blank');
                        printWindow.document.write(html);
                        printWindow.document.close();
                    });
            });

        });
    </script>
}