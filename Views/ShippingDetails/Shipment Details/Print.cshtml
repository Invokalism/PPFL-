@model List<ListReport1._3.Models.ShippingDetails>

@{
    Layout = null;   // VERY IMPORTANT
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Shipment Report</title>
    <style>
        body {
            font-family: Arial;
            padding: 20px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            border: 1px solid black;
            padding: 6px;
            font-size: 12px;
        }

        th {
            background-color: #f2f2f2;
        }
    </style>
</head>
<body onload="window.print()">

    <h2>Shipment Details</h2>

    <table>
        <thead>
            <tr>
                <th>Job No</th>
                <th>Trade</th>
                <th>HBL No</th>
                <th>MBL No</th>
                <th>ATA</th>
                <th>POL/POD</th>
                <th>Shipper</th>
                <th>Vessel</th>
                <th>Commodity</th>
                <th>Teus</th>
                <th>Volume</th>
                <th>Measurement</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.JobNo</td>
                    <td>@item.Trade</td>
                    <td>@item.HblNo</td>
                    <td>@item.MblNo</td>
                    <td>@item.Ata</td>
                    <td>@item.PolPod</td>
                    <td>@item.Shipper</td>
                    <td>@item.Vessel</td>
                    <td>@item.Commodity</td>
                    <td>@item.Teus</td>
                    <td>@item.Volume</td>
                    <td>@item.Measurement</td>
                </tr>
            }
        </tbody>
    </table>

</body>
</html>